{
  "name": "rhythmquest",
  "version": "1.0.0",
  "description": "RhythmQuest - Music & Academic Learning App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --win --dir",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.rhythmquest.app",
    "productName": "RhythmQuest",
    "directories": {
      "output": "../dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": ["**/*"]
      }
    ]
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4"
  }
}
